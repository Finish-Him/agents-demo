# ── LLM Providers ─────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
OPENAI_API_KEY=sk-proj-...
ANTHROPIC_API_KEY=sk-ant-api03-...
GOOGLE_API_KEY=AIza...

# ── Observability (LangSmith) ─────────────────────────────────────────
LANGSMITH_API_KEY=lsv2_pt_...
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=agents-demo-arquimedes

# ── HuggingFace ───────────────────────────────────────────────────────
HF_TOKEN=hf_...
HF_FINETUNED_REPO=<hf-user>/arquimedes-math-lora
HF_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Supabase (production memory + pgvector option) ────────────────────
SUPABASE_ACCESS_TOKEN=sbp_...

# ── Default model ─────────────────────────────────────────────────────
DEFAULT_MODEL=qwen/qwen3-235b-a22b

# ── RAG ───────────────────────────────────────────────────────────────
CHROMA_PATH=./data/chroma
RAG_COLLECTION=arquimedes_math
RAG_K=4
RAG_RERANK=false
CHUNK_SIZE=800
CHUNK_OVERLAP=120
OPENAI_EMBED_MODEL=text-embedding-3-small

# ── Memory ────────────────────────────────────────────────────────────
MEMORY_BACKEND=semantic           # semantic | memory
MEMORY_CHROMA_PATH=./data/memory_chroma
SQLITE_CHECKPOINT_PATH=./data/checkpoints.sqlite

# ── Fine-tuning ───────────────────────────────────────────────────────
FT_DEVICE=auto                    # auto | cuda | cpu
FT_LOAD_IN_4BIT=true

# ── MCP server ────────────────────────────────────────────────────────
MCP_TRANSPORT=stdio               # stdio | sse
MCP_PORT=8765

# ── GitHub (used by Atlas agent) ──────────────────────────────────────
GITHUB_TOKEN=ghp_...
